{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentic-development-system/schemas/loop.contract.schema.json",
  "title": "Agentic Loop Contract",
  "type": "object",
  "required": ["contract_order", "observe", "plan", "act", "verify", "update_state", "decide_next_loop"],
  "properties": {
    "contract_order": {
      "type": "array",
      "items": {
        "enum": ["observe", "plan", "act", "verify", "update_state", "decide_next_loop"]
      }
    },
    "observe": {
      "type": "object"
    },
    "plan": {
      "type": "object"
    },
    "act": {
      "type": "object"
    },
    "verify": {
      "type": "object"
    },
    "update_state": {
      "type": "object"
    },
    "decide_next_loop": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
