{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentic-development-system/schemas/project.state.schema.json",
  "title": "Machine-readable Project State",
  "type": "object",
  "required": ["schema_version", "repo_root", "source_documents", "goal", "current_state", "needs_confirmation"],
  "properties": {
    "schema_version": {
      "const": "project-state/v1"
    },
    "repo_root": {
      "type": "string"
    },
    "source_documents": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "goal": {
      "type": "object"
    },
    "current_state": {
      "type": "object"
    },
    "needs_confirmation": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
